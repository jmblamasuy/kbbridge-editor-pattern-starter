{
  "name": "my-pattern-extension",
  "displayName": "My Pattern Extension (KB Editor)",
  "description": "Starter template to extend KB Editor for a GeneXus pattern (custom types, captions, custom actions).",
  "version": "0.1.0",
  "publisher": "your-publisher",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "genexus",
    "patterns",
    "kb-editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmblamasuy/kbbridge-editor-pattern-starter"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "kbbridge.genexus-visual-editor"
  ],
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -watch",
    "bundle": "node scripts/bundle-dependencies.js",
    "vscode:prepublish": "npm run compile && npm run bundle",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@kbbridge/genexus-sdk": "file:./vendor/genexus-sdk"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.24.0"
  }
}
